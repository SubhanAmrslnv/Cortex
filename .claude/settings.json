{
  "statusLine": {
    "type": "command",
    "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/statusline/render.sh\""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/runtime/prompt-router.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/guards/pre-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/events/bus.sh\" publish FileChanged"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/runtime/stop-build.sh\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/guards/permission-request.sh\""
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/guards/permission-denied.sh\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CORTEX_ROOT:-$(pwd)/.claude}/core/hooks/runtime/post-error-analyzer.sh\""
          }
        ]
      }
    ]
  }
}
