{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/guards/pre-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/post-format.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/post-scan.sh"
          },
          {
            "type": "command",
            "command": "node ~/.cortex/core/hooks/runtime/post-code-intel.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/post-audit-log.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/stop-build.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/runtime/prompt-optimizer.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/guards/permission-request.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.cortex/core/hooks/guards/permission-denied.sh"
          }
        ]
      }
    ]
  }
}
