{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/guards/pre-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/post-format.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/post-audit-log.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/stop-build.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/guards/permission-request.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/guards/permission-denied.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/post-error-analyzer.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/notification.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/task-tracker.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CORTEX_ROOT:-$HOME/.cortex}/core/hooks/runtime/task-tracker.sh"
          }
        ]
      }
    ]
  }
}
